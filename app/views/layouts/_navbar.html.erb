<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container-fluid">

    <%= link_to "Products", root_path, class: "navbar-brand" %>

    <ul class="navbar-nav ms-auto">

      <% if logged_in? %>

        <!-- Hello -->
        <li class="nav-item">
          <span class="nav-link text-light">
            Hello, <%= current_user.name %>
          </span>
        </li>

        <% unless current_user.admin? %>

          <!-- Cart -->
          <li class="nav-item">
            <%= link_to "Cart (#{current_user.cart&.cart_items&.count || 0})",
                        cart_path,
                        class: "nav-link" %>
          </li>

          <!-- Wishlist -->
          <li class="nav-item">
            <%= link_to "Wishlist (#{current_user.wishlists.count})",
                        wishlists_path,
                        class: "nav-link" %>
          </li>

        <% end %>

        <!-- Profile -->
        <li class="nav-item">
          <%= link_to "My Profile",
                      profile_path,
                      class: "nav-link" %>
        </li>

      <% else %>

        <li class="nav-item">
          <%= link_to "Login", login_path, class: "nav-link" %>
        </li>

        <li class="nav-item">
          <%= link_to "Sign Up", new_user_path, class: "nav-link" %>
        </li>

      <% end %>

    </ul>
  </div>
</nav>