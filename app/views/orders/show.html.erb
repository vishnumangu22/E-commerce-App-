<div class="container mt-4">

  <h2 class="mb-4">Order Details</h2>

  <p><strong>Order ID:</strong> <%= @order.id %></p>
  <p><strong>Date:</strong> <%= @order.created_at.strftime("%d %B %Y") %></p>
  <p><strong>Status:</strong> <%= @order.status.capitalize %></p>

  <hr>

  <% subtotal = 0 %>

  <% @order.order_items.each do |item| %>
    <% line_total = item.price * item.quantity %>
    <% subtotal += line_total %>

    <div class="mb-3">
      <strong><%= item.product.name %></strong><br>
      Quantity: <%= item.quantity %><br>
      Price: ₹ <%= item.price %><br>
      Subtotal: ₹ <%= line_total %>
    </div>
    <hr>
  <% end %>

  <% gst = (subtotal * 0.18).round(2) %>
  <% grand_total = subtotal + gst %>

  <div class="mt-3">
    <p><strong>Subtotal:</strong> ₹ <%= subtotal %></p>
    <p><strong>GST (18%):</strong> ₹ <%= gst %></p>
    <h4><strong>Total Paid:</strong> ₹ <%= grand_total %></h4>
  </div>

  <br>

  <%= link_to "Download Invoice",
              invoice_order_path(@order),
              class: "btn btn-success me-2" %>

  <%= link_to "Back to Orders",
              orders_path,
              class: "btn btn-secondary" %>

</div>