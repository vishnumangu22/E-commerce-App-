<h2>New Product</h2>

<%= form_with model: [:admin, @product], local: true, html: { multipart: true } do |f| %>
  <% if @product.errors.any? %>
    <div style="color:red;">
      <h4>Errors:</h4>
      <ul>
        <% @product.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name %><br>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :description %><br>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.label :price %><br>
    <%= f.number_field :price, step: 0.01 %>
  </div>

  <div>
    <%= f.label :stock %><br>
    <%= f.number_field :stock %>
  </div>

  <div>
    <%= f.label :image %><br>
    <%= f.file_field :image %>
  </div>

  <div class="mb-3">
  <%= f.label :category_id, "Category" %>
    <%= f.collection_select :category_id,
                            Category.all,
                            :id,
                            :name,
                            { prompt: "Select Category" },
                            { class: "form-select" } %>
  </div>

  

  <br>
  <%= f.submit "Create Product", class: "btn btn-primary" %>

<% end %>

<br>
<%= link_to "Back", admin_products_path %>