<div class="container mt-4">

  <h2 class="mb-4">Your Cart</h2>

  <% if @cart.cart_items.any? %>

    <% @cart.cart_items.each do |item| %>

      <div class="card mb-3 shadow-sm">
        <div class="card-body">

          <div class="row align-items-center">
            <div class="col-md-2 text-center">
              <% if item.product.image.attached? %>
                <%= image_tag item.product.image,
                              class: "img-fluid rounded",
                              style: "max-height: 80px;" %>
              <% else %>
                <div class="text-muted small">
                  No Image
                </div>
              <% end %>
            </div>

            <div class="col-md-3">
              <h5 class="card-title mb-0">
                <%= item.product.name %>
              </h5>
            </div>

            <div class="col-md-3 text-center">
              <div class="d-flex justify-content-center align-items-center gap-2">

                <%= button_to "-",
                              cart_item_path(item, type: "decrease"),
                              method: :patch,
                              class: "btn btn-sm btn-outline-danger" %>

                <span class="fw-bold fs-5"><%= item.quantity %></span>

                <%= button_to "+",
                              cart_item_path(item, type: "increase"),
                              method: :patch,
                              class: "btn btn-sm btn-outline-success" %>

              </div>
            </div>

            <div class="col-md-4 text-end">

              <p class="mb-2 fw-bold">
                Rs. <%= item.product.price * item.quantity %>
              </p>

              <%= button_to "Remove",
                            cart_item_path(item),
                            method: :delete,
                            class: "btn btn-sm btn-outline-danger" %>

            </div>

          </div>

        </div>
      </div>

    <% end %>


    <div class="card shadow-sm mt-4">
      <div class="card-body">

        <div class="d-flex justify-content-between">
          <span>Subtotal</span>
          <span>Rs. <%= @cart.subtotal %></span>
        </div>

        <div class="d-flex justify-content-between">
          <span>GST (18%)</span>
          <span>Rs. <%= @cart.gst %></span>
        </div>

        <hr>

        <div class="d-flex justify-content-between fs-5 fw-bold">
          <span>Grand Total</span>
          <span>Rs. <%= @cart.grand_total %></span>
        </div>

        <div class="text-end mt-3">
          <%= button_to "Checkout",
                        orders_path,
                        method: :post,
                        class: "btn btn-success btn-lg" %>
        </div>

      </div>
    </div>

  <% else %>

    <div class="alert alert-info">
      Your cart is empty.
    </div>

  <% end %>

</div>