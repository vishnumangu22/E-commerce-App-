<h2>Order Details</h2>

<p><strong>Order ID:</strong> <%= @order.id %></p>
<p><strong>Date:</strong> <%= @order.created_at.strftime("%d %B %Y") %></p>
<p><strong>Status:</strong> <%= @order.status.capitalize %></p>

<hr>

<% @order.order_items.each do |item| %>
  <div>
    <strong><%= item.product.name %></strong><br>
    Quantity: <%= item.quantity %><br>
    Price: ₹ <%= item.price %><br>
    Subtotal: ₹ <%= item.price * item.quantity %>
  </div>
  <hr>
<% end %>

<h3>Total Paid: ₹ <%= @order.total_amount %></h3>

<%= link_to "Download Invoice",
            invoice_order_path(@order),
            class: "btn btn-success" %>

<%= link_to "Back to Orders", orders_path %>