<h2><%= @product.name %></h2>

<p><%= @product.description %></p>

<p><strong>Price:</strong> ₹ <%= @product.price %></p>
<p><strong>Stock:</strong> <%= @product.stock %></p>

<hr>



<% if !logged_in? %>

  <!-- Guest -->
  <p>Please login to purchase this product.</p>

<% elsif current_user.admin? %>

  <!-- Admin -->
  <p><strong>Admins cannot purchase products.</strong></p>

<% elsif @product.stock <= 0 %>

  <!-- Out of Stock -->
  <p style="color:red;"><strong>Out of Stock</strong></p>

<% else %>

  <!-- Customer -->
  <%= button_to "Add to Cart",
                cart_items_path(product_id: @product.id),
                method: :post,
                class: "btn btn-primary" %>

<% end %>

<br><br>

<%= link_to "Back to Products",
            root_path,
            class: "btn btn-secondary" %>